{
  "name": "compound-interest-calculator-ui-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright UI regression tests for the Streamlit compound interest calculator",
  "scripts": {
    "ui:test": "playwright test",
    "ui:test:positive": "playwright test ui-tests/regression/positive",
    "ui:test:negative": "playwright test ui-tests/regression/negative",
    "ui:test:headed": "playwright test --headed",
    "ui:test:watch": "playwright test ui-tests/regression --project=chromium --headed --workers=1 --timeout=120000",
    "ui:test:headed:one": "playwright test ui-tests/regression/positive/calculator.currency-format.spec.ts --project=chromium --headed --workers=1",
    "ui:test:debug": "PWDEBUG=1 playwright test ui-tests/regression/positive/calculator.currency-format.spec.ts --project=chromium --workers=1",
    "ui:report": "playwright show-report",
    "ui:test:json": "playwright test --reporter=json > playwright-results.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0"
  }
}